# Public web configuration. These are examples only; never commit live credentials.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Server-only values. Keep these outside client bundles.
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
SUPABASE_WEBHOOK_SECRET=replace-with-a-random-secret
CRON_SECRET=replace-with-a-random-secret

# Optional production integrations
RESEND_API_KEY=re_your_key
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret
MERCADO_PAGO_ACCESS_TOKEN=TEST-your-token
